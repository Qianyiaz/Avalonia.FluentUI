<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia.FluentUI.Views.Pages.LoginPage">
    <Border
        Padding="25"
        BorderThickness="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource ButtonBackground}"
        CornerRadius="{DynamicResource OverlayCornerRadius}">
        <StackPanel VerticalAlignment="Center" MinWidth="400" Spacing="8">
            <TextBlock FontWeight="Bold" FontSize="25">Login</TextBlock>
            <TextBox Classes="clearButton" IsVisible="{Binding !#CheckBox.IsChecked}" PlaceholderText="Username" />
            <TextBox Classes="revealPasswordButton" IsVisible="{Binding !#CheckBox.IsChecked}"
                     PlaceholderText="Password" PasswordChar="*" />
            <TextBox Classes="revealPasswordButton" IsVisible="{Binding #CheckBox.IsChecked}" PlaceholderText="Token"
                     PasswordChar="*" />
            <WrapPanel ItemSpacing="5">
                <CheckBox Name="CheckBox" Content="Use token to login" />
                <CheckBox IsChecked="True" Content="Stay logged in" />
            </WrapPanel>
            <Button Classes="accent" HotKey="Enter" Content="Login" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
</UserControl>