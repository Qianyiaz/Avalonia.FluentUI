<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia.FluentUI.Views.Pages.LoginPage">
    <Border
        Padding="25"
        BorderThickness="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource ButtonBackground}"
        CornerRadius="{DynamicResource OverlayCornerRadius}">
        <StackPanel VerticalAlignment="Center" MinWidth="400" Spacing="8">
            <TextBlock FontWeight="Bold" FontSize="25">登录界面</TextBlock>
            <TextBox IsVisible="{Binding !#CheckBox.IsChecked}" PlaceholderText="用户名" />
            <TextBox IsVisible="{Binding !#CheckBox.IsChecked}" PlaceholderText="密码" PasswordChar="*" />
            <TextBox IsVisible="{Binding #CheckBox.IsChecked}" PlaceholderText="用户令牌" PasswordChar="*" />
            <WrapPanel ItemSpacing="5">
                <CheckBox Name="CheckBox" Content="使用令牌(token)登录" />
                <CheckBox IsChecked="True" Content="保持登录" />
            </WrapPanel>
            <Button Classes="accent" HotKey="Enter" Content="登录" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
</UserControl>
