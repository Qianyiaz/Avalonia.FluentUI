<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia.FluentUI.Views.Pages.RadioButtonPage">
    <Border
        Padding="25"
        BorderThickness="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource ButtonBackground}"
        CornerRadius="{DynamicResource OverlayCornerRadius}">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" ColumnDefinitions="*,*" ColumnSpacing="8">
            <StackPanel>
                <TextBlock Margin="0 10 0 5">First Group</TextBlock>
                <RadioButton Content="First Option" />
                <RadioButton Content="Second Option" />
                <RadioButton IsEnabled="False" Content="Third Option" />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Margin="0 10 0 5">Second Group</TextBlock>
                <RadioButton Content="Fourth Option" />
                <RadioButton Content="Fifth Option" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>