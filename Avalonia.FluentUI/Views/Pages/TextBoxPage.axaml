<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia.FluentUI.ViewModels.Pages"
             x:Class="Avalonia.FluentUI.Views.Pages.TextBoxPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" Spacing="16">
            <TextBlock
                Text="TextBoxs"
                FontSize="45" />

            <TextBox
                ToolTip.Tip="A tooltip."
                PlaceholderText="I am a TextBox with a watermark and a tooltip."
                Classes="clearButton"
                AcceptsReturn="False"
                IsReadOnly="False" />

            <TextBox
                Name="Password"
                PasswordChar="*"
                ToolTip.Tip="A tooltip."
                Classes="revealPasswordButton"
                PlaceholderText="I am a PasswordBox with a watermark and a tooltip."/>

            <TextBox
                MinHeight="125"
                AcceptsReturn="True"
                Text="This is a multi-line TextBox. You can type multiple lines of text here." />

            <MaskedTextBox
                ToolTip.Tip="I'm a masked textbox."
                Mask="(+09) 000 000 0000" />

            <AutoCompleteBox
                FilterMode="StartsWith"
                ItemsSource="{x:Static vm:TextBoxPageViewModel.AnimalList}"
                PlaceholderText="Choose your favourite animal." />
        </StackPanel>
    </ScrollViewer>
</UserControl>