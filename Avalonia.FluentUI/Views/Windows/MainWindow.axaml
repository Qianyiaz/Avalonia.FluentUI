<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    x:Class="Avalonia.FluentUI.Views.Windows.MainWindow"
    TransparencyLevelHint="Mica,AcrylicBlur,None"
    Background="Transparent"
    Title="Avalonia.FluentUI"
    Icon="/app.ico">

    <ui:FANavigationView
        Name="RootNavigation"
        PaneDisplayMode="Auto"
        IsSettingsVisible="False"
        SelectionChanged="OnSelectionChanged">
        <ui:FANavigationView.MenuItems>
            <ui:FANavigationViewItem IconSource="Home" Content="Home" />
            <ui:FANavigationViewItem IconSource="ImageAltText" Content="TextBox" />
            <ui:FANavigationViewItem IconSource="List" Content="ListBox" />
            <ui:FANavigationViewItem IconSource="RadioButtonFilled" Content="RadioButton" />
            <ui:FANavigationViewItem IconSource="Earth" Content="Login"/>
        </ui:FANavigationView.MenuItems>

        <ui:FANavigationView.FooterMenuItems>
            <ui:FANavigationViewItem IconSource="Settings" Content="Settings" />
        </ui:FANavigationView.FooterMenuItems>

        <ui:FAFrame Name="Frame" />
    </ui:FANavigationView>
</Window>